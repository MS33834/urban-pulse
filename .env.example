# Urban Pulse — Environment Variables

# Server
APP_HOST=127.0.0.1
APP_PORT=8000
WORKERS=1
APP_RELOAD=true

# Security
SECRET_KEY=change-this-in-production
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
TRUSTED_HOSTS=localhost,127.0.0.1

# Default region & industry (for analysis endpoints)
DEFAULT_REGION=深圳
DEFAULT_INDUSTRY=半导体
